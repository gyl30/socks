@startuml
!theme plain
hide empty members

package "Infrastructure" {
    class io_context_pool {
        + run()
        + stop()
        + get_io_context()
    }

    class io_worker {
        + io_context
    }
}

package "Client Inbound" {
    class socks_inbound {
        + start()
        + stop()
        - accept_loop()
    }

    class socks_control_session {
        + start()
        - handshake()
        - read_request()
    }

    class socks_tcp_connect_session {
        + start(host, port)
        - run(host, port)
        - idle_watchdog()
    }

    class socks_udp_associate_session {
        + start(host, port)
        - run(host, port)
        - ensure_proxy_outbound()
        - idle_watchdog()
    }

    class tproxy_inbound {
        + start()
        + stop()
        - accept_tcp_loop()
        - accept_udp_loop()
    }

    class tproxy_tcp_session {
        + start()
        - run()
        - idle_watchdog()
    }

    class tproxy_udp_session {
        + start()
        + stop()
        - run()
        - open_proxy_outbound()
        - idle_watchdog()
    }

    class tun_inbound {
        + start()
        + stop()
        - read_loop()
        - timer_loop()
        - init_stack()
    }

    class tun_device

    class tun_tcp_session {
        + start()
        - run()
        - select_backend()
        - idle_watchdog()
    }

    class tun_udp_session {
        + start()
        + stop()
        - run()
        - open_proxy_outbound()
        - idle_watchdog()
    }

    class router {
        + load()
        + decide_ip()
        + decide_domain()
    }
}

package "Upstream" {
    abstract class tcp_outbound_stream {
        + connect(host, port)
        + write(data, ec)
        + read(buf, ec)
        + shutdown_send(ec)
        + close()
    }

    class direct_tcp_outbound

    class proxy_tcp_outbound

    class udp_proxy_outbound {
        + connect()
        + send_datagram()
        + receive_datagram()
        + close()
    }
}

package "Proxy Protocol + Reality" {
    class proxy_reality_connection {
        + connect()
        + write()
        + write_packet()
        + read_some()
        + read_packet()
        + shutdown_send()
        + close()
    }

    class reality_engine {
        + read_buffer()
        + commit_read()
        + decrypt_record()
        + encrypt_record()
    }

    class "proxy::tcp_connect_request" as tcp_connect_request
    class "proxy::tcp_connect_reply" as tcp_connect_reply
    class "proxy::udp_associate_request" as udp_associate_request
    class "proxy::udp_associate_reply" as udp_associate_reply
    class "proxy::udp_datagram" as udp_datagram
}

package "Server Side" {
    class reality_inbound {
        + start()
        + stop()
        - accept_loop()
        - handle(socket, conn_id)
        - process_proxy_request()
    }

    class reality_tcp_connect_session {
        + start(request)
        - run(request)
        - send_connect_reply()
        - client_to_target()
        - target_to_client()
        - idle_watchdog()
    }

    class reality_udp_associate_session {
        + start(request)
        - start_impl(request)
        - connection_to_udp()
        - udp_to_connection()
        - idle_watchdog()
    }

    class replay_cache
}

socks_inbound o-- io_context_pool
socks_inbound *-- router
socks_inbound ..> socks_control_session : creates

socks_control_session ..> socks_tcp_connect_session : CONNECT
socks_control_session ..> socks_udp_associate_session : UDP ASSOCIATE

socks_tcp_connect_session ..> router
socks_tcp_connect_session ..> tcp_outbound_stream : create_backend
socks_udp_associate_session ..> router
socks_udp_associate_session ..> udp_proxy_outbound : ensure_proxy_outbound

tproxy_inbound o-- io_context_pool
tproxy_inbound *-- router
tproxy_inbound ..> tproxy_tcp_session : creates
tproxy_inbound ..> tproxy_udp_session : creates

tproxy_tcp_session ..> router
tproxy_tcp_session ..> tcp_outbound_stream : select_backend
tproxy_udp_session ..> udp_proxy_outbound

tun_inbound o-- tun_device
tun_inbound *-- router
tun_inbound ..> tun_tcp_session : creates
tun_inbound ..> tun_udp_session : creates

tun_tcp_session ..> router
tun_tcp_session ..> tcp_outbound_stream : select_backend
tun_udp_session ..> router
tun_udp_session ..> udp_proxy_outbound

tcp_outbound_stream <|-- direct_tcp_outbound
tcp_outbound_stream <|-- proxy_tcp_outbound
proxy_tcp_outbound ..> proxy_reality_connection
udp_proxy_outbound ..> proxy_reality_connection

proxy_reality_connection *-- reality_engine
proxy_reality_connection ..> tcp_connect_request
proxy_reality_connection ..> tcp_connect_reply
proxy_reality_connection ..> udp_associate_request
proxy_reality_connection ..> udp_associate_reply
proxy_reality_connection ..> udp_datagram

reality_inbound o-- io_context_pool
reality_inbound *-- replay_cache
reality_inbound ..> proxy_reality_connection : wraps accepted socket
reality_inbound ..> reality_tcp_connect_session : tcp_connect_request
reality_inbound ..> reality_udp_associate_session : udp_associate_request

reality_tcp_connect_session ..> proxy_reality_connection
reality_udp_associate_session ..> proxy_reality_connection

note right of proxy_reality_connection
  route=proxy 时：
  一次 TCP 请求或一个 UDP 会话
  对应一条 REALITY 连接。
  连接结束后直接销毁，
  不再回收到连接池。
end note

note right of reality_inbound
  服务端不再接收多路 stream。
  认证成功后只处理一个代理会话。
end note

note bottom of replay_cache
  运行时残留已清理：
  无 connection_tracker，
  关闭错误判断统一由 net_utils 提供。
end note

@enduml
