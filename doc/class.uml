@startuml
!theme plain
hide empty members

package "Infrastructure" {
    class io_context_pool {
        + run()
        + stop()
        + get_io_context()
    }

    class io_worker {
        + io_context
    }
}

package "Client Inbound" {
    class socks_client {
        + start()
        + stop()
        - accept_loop()
    }

    class socks_session {
        + start()
        - handshake()
        - read_request()
    }

    class tcp_socks_session {
        + start(host, port)
        - run(host, port)
        - idle_watchdog()
    }

    class udp_socks_session {
        + start(host, port)
        - run(host, port)
        - ensure_proxy_upstream()
        - idle_watchdog()
    }

    class tproxy_client {
        + start()
        + stop()
        - accept_tcp_loop()
        - accept_udp_loop()
    }

    class tproxy_tcp_session {
        + start()
        - run()
        - idle_watchdog()
    }

    class tproxy_udp_session {
        + start()
        + stop()
        - run()
        - open_proxy_upstream()
        - idle_watchdog()
    }

    class tun_client {
        + start()
        + stop()
        - read_loop()
        - timer_loop()
        - init_stack()
    }

    class tun_device

    class tun_tcp_session {
        + start()
        - run()
        - select_backend()
        - idle_watchdog()
    }

    class tun_udp_session {
        + start()
        + stop()
        - run()
        - open_proxy_upstream()
        - idle_watchdog()
    }

    class router {
        + load()
        + decide_ip()
        + decide_domain()
    }
}

package "Upstream" {
    abstract class upstream {
        + connect(host, port)
        + write(data, ec)
        + read(buf, ec)
        + shutdown_send(ec)
        + close()
    }

    class direct_upstream

    class proxy_upstream

    class proxy_udp_upstream {
        + connect()
        + send_datagram()
        + receive_datagram()
        + close()
    }
}

package "Proxy Protocol + Reality" {
    class proxy_reality_connection {
        + connect()
        + write()
        + write_packet()
        + read_some()
        + read_packet()
        + shutdown_send()
        + close()
    }

    class reality_engine {
        + read_buffer()
        + commit_read()
        + decrypt_record()
        + encrypt_record()
    }

    class "proxy::tcp_connect_request" as tcp_connect_request
    class "proxy::tcp_connect_reply" as tcp_connect_reply
    class "proxy::udp_associate_request" as udp_associate_request
    class "proxy::udp_associate_reply" as udp_associate_reply
    class "proxy::udp_datagram" as udp_datagram
}

package "Server Side" {
    class remote_server {
        + start()
        + stop()
        - accept_loop()
        - handle(socket, conn_id)
        - process_proxy_request()
    }

    class remote_tcp_proxy_session {
        + start(request)
        - run(request)
        - send_connect_reply()
        - client_to_target()
        - target_to_client()
        - idle_watchdog()
    }

    class remote_udp_proxy_session {
        + start(request)
        - start_impl(request)
        - connection_to_udp()
        - udp_to_connection()
        - idle_watchdog()
    }

    class replay_cache
}

socks_client o-- io_context_pool
socks_client *-- router
socks_client ..> socks_session : creates

socks_session ..> tcp_socks_session : CONNECT
socks_session ..> udp_socks_session : UDP ASSOCIATE

tcp_socks_session ..> router
tcp_socks_session ..> upstream : create_backend
udp_socks_session ..> router
udp_socks_session ..> proxy_udp_upstream : ensure_proxy_upstream

tproxy_client o-- io_context_pool
tproxy_client *-- router
tproxy_client ..> tproxy_tcp_session : creates
tproxy_client ..> tproxy_udp_session : creates

tproxy_tcp_session ..> router
tproxy_tcp_session ..> upstream : select_backend
tproxy_udp_session ..> proxy_udp_upstream

tun_client o-- tun_device
tun_client *-- router
tun_client ..> tun_tcp_session : creates
tun_client ..> tun_udp_session : creates

tun_tcp_session ..> router
tun_tcp_session ..> upstream : select_backend
tun_udp_session ..> router
tun_udp_session ..> proxy_udp_upstream

upstream <|-- direct_upstream
upstream <|-- proxy_upstream
proxy_upstream ..> proxy_reality_connection
proxy_udp_upstream ..> proxy_reality_connection

proxy_reality_connection *-- reality_engine
proxy_reality_connection ..> tcp_connect_request
proxy_reality_connection ..> tcp_connect_reply
proxy_reality_connection ..> udp_associate_request
proxy_reality_connection ..> udp_associate_reply
proxy_reality_connection ..> udp_datagram

remote_server o-- io_context_pool
remote_server *-- replay_cache
remote_server ..> proxy_reality_connection : wraps accepted socket
remote_server ..> remote_tcp_proxy_session : tcp_connect_request
remote_server ..> remote_udp_proxy_session : udp_associate_request

remote_tcp_proxy_session ..> proxy_reality_connection
remote_udp_proxy_session ..> proxy_reality_connection

note right of proxy_reality_connection
  route=proxy 时：
  一次 TCP 请求或一个 UDP 会话
  对应一条 REALITY 连接。
end note

note right of remote_server
  服务端不再接收多路 stream。
  认证成功后只处理一个代理会话。
end note

@enduml
