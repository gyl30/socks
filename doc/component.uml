@startuml
!theme plain
skinparam componentStyle uml2

package "Client Process" {
    [SOCKS5 Listener] as SocksListener
    [SOCKS Session] as SocksSession
    [TPROXY Inbound] as TproxyInbound
    [TPROXY TCP Session] as TproxyTcpSession
    [TPROXY UDP Session] as TproxyUdpSession
    [TUN Device] as TunDevice
    [tun_inbound] as TunInbound
    [tun_tcp_session] as TunTcpSession
    [tun_udp_session] as TunUdpSession

    [Router] as Router
    [direct_tcp_outbound] as DirectUpstream
    [proxy_tcp_outbound] as ProxyUpstream
    [udp_proxy_outbound] as ProxyUdpUpstream

    [proxy_reality_connection (client)] as ClientConn
    [reality_engine (client)] as ClientReality
}

cloud "Internet" {
    [TLS-like TCP Connection] as Network
}

package "Server Process" {
    [reality_inbound] as RealityInbound
    [proxy_reality_connection (server)] as ServerConn
    [reality_engine (server)] as ServerReality
    [reality_tcp_connect_session] as RealityTcp
    [reality_udp_associate_session] as RealityUdp
}

[User App] as App
[Target Service] as Target

App --> SocksListener : SOCKS5 TCP
SocksListener --> SocksSession : create

App --> TproxyInbound : redirected TCP/UDP
TproxyInbound --> TproxyTcpSession : TCP create
TproxyInbound --> TproxyUdpSession : UDP create

App --> TunDevice : routed L3 packets
TunDevice --> TunInbound : read/write packets
TunInbound --> TunTcpSession : TCP via lwIP
TunInbound --> TunUdpSession : UDP via lwIP

SocksSession --> Router : decide_ip / decide_domain
TproxyTcpSession --> Router : decide_ip
TproxyUdpSession --> Router : decide_ip
TunTcpSession --> Router : decide_ip / decide_domain
TunUdpSession --> Router : decide_ip

Router --> DirectUpstream : route=direct,tcp
Router --> ProxyUpstream : route=proxy,tcp
Router --> ProxyUdpUpstream : route=proxy,udp

DirectUpstream --> Target : direct TCP
SocksSession --> ProxyUdpUpstream : UDP ASSOCIATE proxy path
TproxyUdpSession --> Target : direct UDP
TunUdpSession --> Target : direct UDP

ProxyUpstream --> ClientConn : one TCP request one connection
ProxyUdpUpstream --> ClientConn : one UDP session one connection
ClientConn --> ClientReality : encrypt/decrypt plaintext
ClientReality <--> Network
Network <--> ServerReality
ServerReality --> ServerConn : decrypt/encrypt plaintext

RealityInbound --> ServerConn : wrap accepted socket
RealityInbound --> RealityTcp : tcp_connect_request
RealityInbound --> RealityUdp : udp_associate_request
RealityTcp --> Target : TCP connect + relay
RealityUdp --> Target : UDP relay

note right of ProxyUpstream
  每个代理 TCP 请求独占一条 REALITY 连接。
  不再有连接池和子会话复用层。
end note

note right of ProxyUdpUpstream
  UDP 保留报文 framing，
  但不再有复用子会话。
  也不再依赖连接跟踪残留逻辑。
end note

note right of RealityInbound
  认证成功后只处理一个代理会话，
  会话结束即关闭整条 REALITY 连接。
end note

note bottom of Router
  当前运行时基线：
  无预建隧道池、
  无 connection_tracker、
  无子会话复用管理器。
end note

@enduml
